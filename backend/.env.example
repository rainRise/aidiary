# ==================== 应用配置 ====================
APP_NAME=印记
APP_VERSION=0.1.0
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ==================== 数据库配置 ====================
# 本地开发使用SQLite
DATABASE_URL=sqlite+aiosqlite:///./yinji.db

# 云端生产使用PostgreSQL（部署时取消注释并配置）
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/yinji

# ==================== JWT认证配置 ====================
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== SMTP邮箱配置 ====================
# 阿里云邮件推送（新加坡）
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_EMAIL=noreply@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_SENDER_NAME=Your App Name

# ==================== 验证码配置 ====================
VERIFICATION_CODE_EXPIRE_MINUTES=5
MAX_CODE_REQUESTS_PER_5MIN=3

# ==================== DeepSeek API配置 ====================
# DeepSeek API Key（用于AI分析）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ==================== 讯飞语音听写（写日记语音输入） ====================
XFYUN_IAT_APPID=
XFYUN_IAT_API_KEY=
XFYUN_IAT_API_SECRET=

# ==================== Qdrant 配置（映记精灵RAG检索） ====================
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=yinji_diary_memory
QDRANT_VECTOR_DIM=256

# ==================== 情绪特征外部词典（可选） ====================
EMOTION_EXT_LEXICON_ENABLED=true
EMOTION_LEXICON_SOURCES=builtin,ntusd,pysenti
EMOTION_EXT_LEXICON_WEIGHT=0.65
# 默认读取 backend/app/data/lexicons 下词典，可按需覆盖路径
# EMOTION_EXT_LEXICON_POS_PATH=/abs/path/ntusd_positive_simplified.txt
# EMOTION_EXT_LEXICON_NEG_PATH=/abs/path/ntusd_negative_simplified.txt

# ==================== Neo4j配置（Phase 4使用） ====================
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password
