{
  "name": "映记日记速记",
  "description": "把用户输入写入映记日记",
  "method": "POST",
  "url": "http://yingjiapp.com/api/v1/integrations/openclaw/ingest",
  "headers": {
    "Authorization": "Bearer {{YINJI_TOKEN}}",
    "Content-Type": "application/json"
  },
  "body": {
    "content": "{{USER_INPUT}}",
    "title": "{{USER_TITLE}}",
    "diary_date": "{{USER_DIARY_DATE_YYYY_MM_DD}}",
    "emotion_tags": [
      "{{USER_EMOTION_TAG_1}}"
    ],
    "importance_score": 5,
    "mode": "append_today"
  }
}
